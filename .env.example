# 复制为 .env 使用
DATABASE_URL=postgresql://docwiki:docwiki@localhost:5432/docwiki
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
# 存储驱动:local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads

# s3 驱动同时覆盖:阿里云 OSS(S3 兼容端点)/ MinIO / 腾讯 COS / Cloudflare R2
# 阿里云 OSS 示例:S3_ENDPOINT=https://s3.oss-cn-hangzhou.aliyuncs.com  S3_REGION=oss-cn-hangzhou
# MinIO 需要 S3_FORCE_PATH_STYLE=true
#S3_ENDPOINT=
#S3_REGION=
#S3_BUCKET=
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_FORCE_PATH_STYLE=false
